# ── Go API (port 8080) ────────────────────────────────────────────────────────
PORT=8080
ENV=development

# URL the Go API uses to reach the Python ML service
ML_SERVICE_URL=http://ml-service:8000   # docker-compose service name
# ML_SERVICE_URL=http://localhost:8000  # local dev (both services running locally)

ML_SERVICE_TIMEOUT=5s

# ── Alerting ─────────────────────────────────────────────────────────────────
# Set to false to disable all fraud alerts
ALERT_ON_FRAUD=true

# Slack: paste your Incoming Webhook URL here
SLACK_WEBHOOK_URL=

# Email: recipient address
ALERT_EMAIL=

# SMTP server settings (required when ALERT_EMAIL is set)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-sender@gmail.com
SMTP_PASSWORD=your-app-password

# ── Python ML service (port 8000) ────────────────────────────────────────────
# Path inside the container where model files are mounted
MODEL_PATH=/app/models
